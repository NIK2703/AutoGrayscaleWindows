<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- Main Window -->
    <system:String x:Key="AppTitle">自动灰度窗口</system:String>
    
    <!-- Settings -->
    <system:String x:Key="SettingsTitle">设置</system:String>
    <system:String x:Key="EnableMonitoring">启用监控</system:String>
    <system:String x:Key="AutoStart">开机自启动</system:String>
    <system:String x:Key="MinimizeToTray">关闭时最小化到托盘</system:String>
    
    <!-- Rules -->
    <system:String x:Key="RulesTitle">规则</system:String>
    <system:String x:Key="ColorListMode">彩色列表</system:String>
    <system:String x:Key="GrayListMode">灰度列表</system:String>
    
    <!-- Rules Table -->
    <system:String x:Key="ColumnActive">启用</system:String>
    <system:String x:Key="ColumnPattern">匹配模式</system:String>
    <system:String x:Key="ColumnMode">模式</system:String>
    <system:String x:Key="ExecutableFile">可执行文件</system:String>
    <system:String x:Key="WindowTitle">窗口标题</system:String>
    <system:String x:Key="WindowClass">窗口类</system:String>
    <system:String x:Key="Folder">可执行文件文件夹</system:String>
    <system:String x:Key="BrowseFolder">选择文件夹</system:String>
    
    <!-- Buttons -->
    <system:String x:Key="AddRule">+ 添加规则</system:String>
    <system:String x:Key="BrowseApp">通过文件资源管理器浏览应用程序</system:String>
    <system:String x:Key="DeleteRule">删除规则</system:String>
    
    <!-- Context Menu -->
    <system:String x:Key="Duplicate">复制</system:String>
    <system:String x:Key="ToggleEnable">启用/禁用</system:String>
    <system:String x:Key="Delete">删除</system:String>
    
    <!-- Tray -->
    <system:String x:Key="TrayOpen">打开</system:String>
    <system:String x:Key="TrayMonitoring">监控</system:String>
    <system:String x:Key="TrayMonitoringEnabled">监控已启用</system:String>
    <system:String x:Key="TrayPaused">已暂停</system:String>
    <system:String x:Key="TrayMonitoringStopped">监控已停止</system:String>
    <system:String x:Key="TrayGrayscaleOn">灰度: 开</system:String>
    <system:String x:Key="TrayGrayscaleOff">灰度: 关</system:String>
    <system:String x:Key="TraySettings">设置...</system:String>
    <system:String x:Key="TrayExit">退出</system:String>
    
</ResourceDictionary>
