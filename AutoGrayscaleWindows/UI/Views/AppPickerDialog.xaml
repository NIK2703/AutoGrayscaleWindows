<Window x:Class="AutoGrayscaleWindows.UI.Views.AppPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор приложения" 
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="350" MinWidth="400"
        Style="{StaticResource WindowBaseStyle}"
        Loaded="Window_Loaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Поиск -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox Grid.Column="0" 
                     Name="SearchTextBox"
                     Style="{StaticResource TextBoxStyle}"
                     VerticalContentAlignment="Center"
                     TextChanged="SearchTextBox_TextChanged"/>
            
            <TextBlock Grid.Column="0"
                       Text="Поиск приложений..."
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       IsHitTestVisible="False"
                       Name="SearchPlaceholder"/>
        </Grid>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" Name="MainTabControl" Margin="0,0,0,12">
            <TabItem Header="Запущенные">
                <TextBlock Text="Загрузка..." 
                           Name="LoadingText"
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextStyle}"/>
            </TabItem>
            <TabItem Header="Выбрать файл...">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Button Grid.Row="0" 
                            Content="Обзор..."
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left"
                            Click="BrowseButton_Click"/>
                    
                    <TextBlock Grid.Row="1" 
                               Text="Выберите исполняемый файл (.exe) для добавления в правило."
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Список приложений -->
        <ListView Grid.Row="2" 
                  Name="ApplicationsListView"
                  SelectionMode="Single"
                  MouseDoubleClick="ApplicationsListView_MouseDoubleClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Image Grid.Column="0" 
                               Source="{Binding Icon}"
                               Width="24" Height="24"
                               Margin="0,0,8,0"/>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"/>
                            <TextBlock Text="{Binding Path}" 
                                       Style="{StaticResource SecondaryTextStyle}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Выбранное приложение -->
        <Border Grid.Row="3" 
                Style="{StaticResource CardStyle}" 
                Margin="0,12,0,0"
                Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" 
                           Text="Выбрано:" 
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                
                <TextBlock Grid.Column="1" 
                           Name="SelectedAppTextBlock"
                           Text="Не выбрано"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,16,0,0">
            <Button Content="Выбрать" 
                    Width="100"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,8,0"
                    Click="SelectButton_Click"
                    IsDefault="True"/>
            <Button Content="Отмена" 
                    Width="100"
                    Style="{StaticResource SecondaryButton}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
