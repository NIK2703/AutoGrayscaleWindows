<ui:FluentWindow x:Class="AutoGrayscaleWindows.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:AutoGrayscaleWindows.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}"
        Height="580" Width="780"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        Closing="MainWindow_OnClosing">
    
    <Window.Resources>
        <!-- Конвертеры -->
        <models:MatchTargetToVisibilityConverter x:Key="MatchTargetToVisibilityConverter"/>
        <models:EnumToIndexConverter x:Key="EnumToIndexConverter"/>
        
        <!-- Стиль для отключения визуального выделения строк DataGrid -->
        <Style TargetType="DataGridRow">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Заголовок окна (TitleBar) -->
        <ui:TitleBar Grid.Row="0"
                     Title="{DynamicResource AppTitle}"
                     ShowMinimize="True"
                     ShowMaximize="True"
                     ShowClose="True"/>
        
        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="24,16,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Карточка настроек -->
            <ui:Card Grid.Row="0" Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Заголовок секции -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16" Grid.Row="0">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="20"
                                      Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                      Margin="0,0,12,0"/>
                        <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <!-- Первая строка: Включить мониторинг и выбор языка -->
                    <Grid Grid.Row="1" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:ToggleSwitch Grid.Column="0"
                                        Name="EnableAppCheckBox"
                                        Content="{DynamicResource EnableMonitoring}"
                                        IsChecked="True"
                                        Checked="Setting_Changed"
                                        Unchecked="Setting_Changed"/>
                        
                        <!-- Выбор языка -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🌐" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ComboBox Name="LanguageComboBox"
                                      Width="140"
                                      VerticalAlignment="Center"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBoxItem Content="Русский" Tag="ru"/>
                                <ComboBoxItem Content="English" Tag="en"/>
                                <ComboBoxItem Content="中文" Tag="zh"/>
                                <ComboBoxItem Content="Español" Tag="es"/>
                                <ComboBoxItem Content="Français" Tag="fr"/>
                                <ComboBoxItem Content="Deutsch" Tag="de"/>
                                <ComboBoxItem Content="日本語" Tag="ja"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Вторая строка: Сворачивать в трей и Запускать с Windows -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:ToggleSwitch Grid.Column="0"
                                        Name="MinimizeToTrayCheckBox"
                                        Content="{DynamicResource MinimizeToTray}"
                                        IsChecked="True"
                                        Checked="Setting_Changed"
                                        Unchecked="Setting_Changed"/>
                        
                        <ui:ToggleSwitch Grid.Column="1"
                                        Name="AutoStartCheckBox"
                                        Content="{DynamicResource AutoStart}"
                                        IsChecked="False"
                                        Checked="Setting_Changed"
                                        Unchecked="Setting_Changed"/>
                    </Grid>
                </Grid>
            </ui:Card>
            
            <!-- Карточка правил приложений -->
            <ui:Card Grid.Row="1" Margin="0,0,0,0"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     VerticalContentAlignment="Stretch"
                     HorizontalContentAlignment="Stretch">
                <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Заголовок секции с переключателем режима в одной строке -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ui:SymbolIcon Grid.Column="0" Symbol="AppsList24" FontSize="20"
                                      Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                      Margin="0,0,12,0"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource RulesTitle}" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        
                        <!-- RadioButton для выбора режима списка -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton Name="ColorListRadio"
                                        Content="{DynamicResource ColorListMode}"
                                        GroupName="ListMode"
                                        Checked="ListModeRadio_Changed"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center"/>
                            <RadioButton Name="GrayListRadio"
                                        Content="{DynamicResource GrayListMode}"
                                        GroupName="ListMode"
                                        Checked="ListModeRadio_Changed"
                                        VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    
                    <!-- Таблица правил -->
                    <DataGrid Grid.Row="1" Name="RulesDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                              VerticalGridLinesBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource ControlFillColorTransparentBrush}"
                              HeadersVisibility="Column"
                              RowHeight="32"
                              ColumnHeaderHeight="28"
                              FontSize="13"
                              RowHeaderWidth="0"
                              HorizontalScrollBarVisibility="Disabled"
                              SelectionUnit="Cell"
                              VerticalAlignment="Stretch"
                              VerticalContentAlignment="Stretch">
                        <DataGrid.Columns>
                            <!-- Активность -->
                            <DataGridTemplateColumn Header="{DynamicResource ColumnActive}" Width="55" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Click="RuleCheckBox_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Паттерн (файл или заголовок) -->
                            <DataGridTemplateColumn Header="{DynamicResource ColumnPattern}" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding AppIdentifier, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                     VerticalAlignment="Center"
                                                     Padding="4,0"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     TextChanged="RuleTextBox_TextChanged"/>
                                            <Button Grid.Column="1"
                                                    Content="..."
                                                    Width="28"
                                                    Height="24"
                                                    Margin="4,0,2,0"
                                                    Padding="0"
                                                    Tag="{Binding}"
                                                    Click="BrowseAppButton_Click"
                                                    ToolTip="{DynamicResource BrowseApp}"
                                                    Visibility="{Binding MatchTarget, Converter={StaticResource MatchTargetToVisibilityConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Режим сопоставления -->
                            <DataGridTemplateColumn Header="{DynamicResource ColumnMode}" Width="200" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedIndex="{Binding MatchTarget, Converter={StaticResource EnumToIndexConverter}, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                  VerticalAlignment="Center"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  SelectionChanged="RuleComboBox_SelectionChanged">
                                            <ComboBoxItem Content="{DynamicResource ExecutableFile}"/>
                                            <ComboBoxItem Content="{DynamicResource WindowTitle}"/>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Удалить -->
                            <DataGridTemplateColumn Header="" Width="40" CanUserResize="False">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕"
                                                Width="24"
                                                Height="24"
                                                Padding="0"
                                                Margin="2,0"
                                                Tag="{Binding}"
                                                Click="DeleteRuleRowButton_Click"
                                                ToolTip="{DynamicResource DeleteRule}"
                                                Background="Transparent"
                                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                BorderThickness="0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Duplicate}" Click="DuplicateRuleContextMenu_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Copy24"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="{DynamicResource ToggleEnable}" Click="ToggleRuleContextMenu_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="ToggleLeft24"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="{DynamicResource Delete}" Click="DeleteRuleContextMenu_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Delete24" Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                    
                    <!-- Кнопки управления правилами -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <ui:Button Name="AddRuleButton"
                                  Content="{DynamicResource AddRule}"
                                  Appearance="Primary"
                                  Margin="0,0,8,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
        </Grid>
    </Grid>
</ui:FluentWindow>
